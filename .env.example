# ── Database ──
MONGODB_URI=mongodb://localhost:27017/stellar-hook

# ── Stellar Network ──
# Use 'TESTNET' for Stellar Testnet, 'PUBLIC' for Mainnet
STELLAR_NETWORK=TESTNET

# ── API Server ──
# Port for the health/status HTTP API (default: 9100)
API_PORT=9100

# ── Logging ──
# Levels: error, warn, info, debug (default: info)
LOG_LEVEL=info
